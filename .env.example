# Backend
PORT=4000
NODE_ENV=development
POSTGRES_DB=decisioncapture
POSTGRES_USER=decision
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgresql://decision:replace-with-a-long-random-postgres-password@localhost:5432/decisioncapture?schema=public
REDIS_URL=redis://localhost:6379
QUEUE_MODE=inline
QUEUE_WORKER_ENABLED=false
FRONTEND_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3088
AUTH_MODE=disabled
AUTH_SESSION_SECRET=replace-with-a-long-random-session-secret
AUTH_ALLOWED_LOGINS=
AUTH_ADMIN_LOGINS=
AUTH_MAINTAINER_LOGINS=
AUTH_REVIEWER_LOGINS=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
GITHUB_API_TOKEN=
# Preferred for bot-authored enrichment and review comments. Configure all three together.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
INGEST_API_TOKEN=replace-with-a-long-random-token

# AI
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
USE_HEURISTIC_AI_FALLBACK=true
AUTO_APPROVE_CONFIDENCE=0.78
DECISION_SCORE_THRESHOLD=35

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
