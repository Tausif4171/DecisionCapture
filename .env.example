# Backend
PORT=4000
NODE_ENV=development
POSTGRES_DB=decisioncapture
POSTGRES_USER=decisioncapture
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgresql://decisioncapture:replace-with-a-long-random-postgres-password@localhost:5432/decisioncapture?schema=public
REDIS_URL=redis://localhost:6379
QUEUE_MODE=inline
QUEUE_WORKER_ENABLED=false
FRONTEND_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3088
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
GITHUB_API_TOKEN=
INGEST_API_TOKEN=replace-with-a-long-random-token
DASHBOARD_API_TOKEN=replace-with-a-different-long-random-token
DEMO_MODE_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# AI
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
USE_HEURISTIC_AI_FALLBACK=true
AUTO_APPROVE_CONFIDENCE=0.78
DECISION_SCORE_THRESHOLD=35

# Frontend
API_INTERNAL_URL=http://localhost:4000
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-with-a-long-random-password
NEXT_PUBLIC_DEMO_MODE_ENABLED=false
