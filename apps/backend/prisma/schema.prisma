generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  APPROVED
  PENDING
  REJECTED
}

enum UserRole {
  ADMIN
  MAINTAINER
  REVIEWER
  VIEWER
}

enum DecisionAuditAction {
  CREATED
  EDITED
  APPROVED
  REJECTED
  REOPENED
}

enum DecisionExtractionMethod {
  UNKNOWN
  OLLAMA
  STRUCTURED_FALLBACK
}

model AppUser {
  id                String              @id @default(cuid())
  githubId          String              @unique
  login             String              @unique
  name              String?
  avatarUrl         String?
  role              UserRole            @default(VIEWER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  approvedDecisions DecisionMemory[]    @relation("ApprovedDecisionUser")
  rejectedDecisions DecisionMemory[]    @relation("RejectedDecisionUser")
  editedDecisions   DecisionMemory[]    @relation("EditedDecisionUser")
  auditLogs         DecisionAuditLog[]

  @@index([role])
  @@map("app_users")
}

model PullRequestRecord {
  id            String           @id @default(cuid())
  prNumber      Int
  title         String
  description   String?
  mergedAt      DateTime?
  author        String
  url           String
  repository    String
  sourcePayload Json?
  createdAt     DateTime         @default(now())
  decisions     DecisionMemory[]

  @@unique([repository, prNumber])
  @@index([repository, createdAt])
  @@map("pr_records")
}

model DecisionMemory {
  id          String            @id @default(cuid())
  decision    String
  reason      String
  alternative String?
  impact      String
  author      String
  sourcePR    String
  repository  String
  filesChanged String[]         @default([])
  confidence  Float
  status      DecisionStatus    @default(PENDING)
  category    String            @default("architecture")
  extractionMethod DecisionExtractionMethod @default(UNKNOWN)
  prRecordId  String?
  prRecord    PullRequestRecord? @relation(fields: [prRecordId], references: [id], onDelete: SetNull)
  approvedByUserId String?
  approvedBy       AppUser?      @relation("ApprovedDecisionUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedByLogin  String?
  approvedAt       DateTime?
  rejectedByUserId String?
  rejectedBy       AppUser?      @relation("RejectedDecisionUser", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  rejectedByLogin  String?
  rejectedAt       DateTime?
  lastEditedByUserId String?
  lastEditedBy       AppUser?    @relation("EditedDecisionUser", fields: [lastEditedByUserId], references: [id], onDelete: SetNull)
  lastEditedByLogin  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  auditLogs   DecisionAuditLog[]

  @@index([status])
  @@index([repository])
  @@index([category])
  @@index([createdAt])
  @@index([approvedByUserId])
  @@index([rejectedByUserId])
  @@index([lastEditedByUserId])
  @@map("decision_memories")
}

model DecisionAuditLog {
  id         String              @id @default(cuid())
  decisionId String
  decision   DecisionMemory      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  action     DecisionAuditAction
  actorUserId String?
  actor       AppUser?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorLogin  String?
  note        String?
  before      Json?
  after       Json?
  createdAt   DateTime           @default(now())

  @@index([decisionId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("decision_audit_logs")
}
